# ============================================================
# Knowledge Collector – Umgebungsvariablen
# Kopieren nach: .env (NIEMALS .env in Git committen!)
# UGREEN NAS / UGOS Pro Konfiguration
# ============================================================

# ------------------------------------------------------------
# DATENBANK (bestehende MySQL auf UGREEN NAS)
# ------------------------------------------------------------
DB_HOST=192.168.0.101
DB_PORT=3306
DB_NAME=knowledge_collector
DB_USER=root
DB_PASSWORD=dein_db_passwort
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20

# ------------------------------------------------------------
# REDIS (interne Cache/Queue – kein externer Zugriff nötig)
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# LLM PROVIDER
# Stufe 1: Ollama (lokal, kostenlos)
# Stufe 2: Claude Haiku/Sonnet
# Stufe 3: OpenAI
# ------------------------------------------------------------

# Ollama läuft auf dem Host-Rechner oder NAS
# Im Docker-Kontext: host.docker.internal = Mac/NAS-Host
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.2
# Weitere verfügbare Modelle: llama3.2:1b, mistral, qwen2.5:7b

# Anthropic Claude (aus _shared/.env.haasch)
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-haiku-4-5-20251001
# Optionen: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Standard-Provider: ollama | claude | openai | auto
# auto = Ollama wenn erreichbar, sonst Claude, sonst OpenAI
DEFAULT_LLM_PROVIDER=auto

# Monatliches Kosten-Limit in EUR (0 = kein Limit)
LLM_MONTHLY_BUDGET_EUR=5.00

# ------------------------------------------------------------
# WEB-SCRAPING
# ------------------------------------------------------------
# Verzögerung zwischen Requests pro Domain (Sekunden)
SCRAPING_DELAY_MIN=1.5
SCRAPING_DELAY_MAX=4.0
# Maximale gleichzeitige Scraper-Threads
MAX_CONCURRENT_SCRAPERS=3
# robots.txt respektieren
RESPECT_ROBOTS_TXT=true
# Browser-Simulation für JS-heavy Seiten (Playwright)
USE_PLAYWRIGHT=false
# User-Agent
USER_AGENT=KnowledgeCollector/1.0 (private; +http://192.168.0.101:8421)

# ------------------------------------------------------------
# SUCHMASCHINE
# ------------------------------------------------------------
# SearXNG (self-hosted, im Docker-Compose enthalten)
SEARXNG_URL=http://searxng:8080
# Fallback: DuckDuckGo (keine API-Key nötig)
SEARCH_FALLBACK=duckduckgo
# Ergebnisse pro Suche
SEARCH_MAX_RESULTS=10

# ------------------------------------------------------------
# APP-KONFIGURATION
# ------------------------------------------------------------
# Backend FastAPI Port
APP_PORT=8420
# Frontend Nginx Port
FRONTEND_PORT=8421
# SearXNG Port
SEARXNG_PORT=8422

# Sicherheit (zufälliger String, z.B.: openssl rand -hex 32)
SECRET_KEY=BITTE_ERSETZEN_MIT_ZUFALLSSTRING_openssl_rand_hex_32

# Log-Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log-Datei (relativ zum Container /app/logs/)
LOG_FILE=knowledge_collector.log

# Zeitzone
TZ=Europe/Berlin

# ------------------------------------------------------------
# BENACHRICHTIGUNGEN (optional)
# ------------------------------------------------------------
# Telegram (optional, für Job-Alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=knowledge@haasch.local

# Pushover (optional)
PUSHOVER_API_KEY=
PUSHOVER_USER_KEY=

# ------------------------------------------------------------
# NAS-SPEZIFISCH (UGREEN DXP2800)
# ------------------------------------------------------------
# Basis-Pfad für persistente Daten auf dem NAS
NAS_DATA_PATH=/volume1/docker/knowledge-collector
# Backup-Ziel
NAS_BACKUP_PATH=/volume1/Backups/knowledge-collector

# ------------------------------------------------------------
# EXPORT / OBSIDIAN (optional)
# ------------------------------------------------------------
# Obsidian Vault auf dem NAS (für automatischen Export)
OBSIDIAN_VAULT_PATH=/volume1/Obsidian/KnowledgeCollector
# Täglicher Export: true | false
OBSIDIAN_AUTO_EXPORT=false
